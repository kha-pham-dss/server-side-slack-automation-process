# -----------------------------------------------------------------------------
# Sao chép file này thành `.env` và điền giá trị. File `.env` đã được .gitignore.
# Chỉ commit `.env.tmp` (template + hướng dẫn).
# -----------------------------------------------------------------------------

# --- Zalo (local only — cookie/session không đặt trong SSM cho máy dev) ---
# zalo-group-id trên AWS: SSM /slack-dishes/zalo-group-id (có thể ghi đè bên dưới khi test).
ZALO_GROUP_ID=

# Trùng với localStorage z_uuid trên chat.zalo.me (zca-js gọi là imei).
ZALO_IMEI=

# Cùng User-Agent trình duyệt đã export cookie.
ZALO_USER_AGENT=

# Cookie: CÁCH 1 — đường dẫn tới file JSON export Chrome (khuyến nghị, file lưu local, không push).
# Dạng: {"url":"https://chat.zalo.me","cookies":[...]}  hoặc copy từ DevTools / extension ZaloDataExtractor.
ZALO_COOKIES_PATH=config/zalo-cookies.local.json

# Cookie: CÁCH 2 — một dòng JSON (bất tiện với file lớn; chỉ dùng khi cần).
# ZALO_COOKIES_JSON=

ZALO_LANGUAGE=vi

# --- Google Sheet / SSM ---
# Không khai báo SHEET_ID hay service account ở đây — đã cấu hình qua Parameter Store
# (/slack-dishes/sheet-id, sheet-credentials, dishes-sheet-name, zalo-summary-range, …).
# Chạy local cần AWS credentials (ví dụ AWS_PROFILE) để script đọc SSM.

# PARAMETER_PREFIX=/slack-dishes

# -----------------------------------------------------------------------------
# Chạy thử (merge: SSM + .env; biến .env ghi đè SSM nếu đã set):
#   node --env-file=.env scripts/zalo/send-sheet-summary-local.mjs
#
# Cài dependency (lần đầu):
#   npm install --prefix scripts/zalo
#   npm install --prefix serverless/zalo-sheet-summary
# -----------------------------------------------------------------------------
